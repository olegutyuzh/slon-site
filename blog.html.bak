<!DOCTYPE html>
<html lang="uk">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Блог — Ігор «Слон» Утюж</title>

  <link rel="stylesheet" href="style.css" />
  <link rel="icon" href="favicon.ico" />
</head>

<body>
  <header class="site-header">
    <div class="container header-inner">
      <div class="logo-block">
        <img src="img/symbol-elephant.png" alt="Символ Слон" class="logo-elephant" />
        <div class="logo-text">
          <div class="logo-title">Ігор «Слон» Утюж</div>
          <div class="logo-subtitle accent-gold">1996 — 2023</div>
        </div>
      </div>

      <nav class="main-nav">
        <a href="blog.html" class="active-lang">UA</a>
        <a href="blog-en.html">EN</a>

        <a href="index.html">Головна</a>
        <a href="biography.html">Біографія</a>
        <a href="contact.html">Контакти</a>
        <a href="blog.html" class="active-lang">Блог</a>
      </nav>
    </div>
  </header>

  <main>
    <section class="section">
  
      <div class="container section-inner">

        <!-- 1. Hero-секція для узгодженості з іншими сторінками -->
        <div class="blog-hero">
          <img src="img/hero-blog-sol.png" alt="Blog hero">
          <div class="blog-hero-text">
              <h1>Блог</h1>
              <p><span class="accent-gold">Новини, спогади, важливі події та оновлення сайту.<br>
              Цей блог ведуть близькі Ігоря — щоб пам'ять про нього жила далі.</span></p>
          </div>
        </div>

        <!-- Hero: текстовий блок замість великого банеру -->
<!--         <div class="blog-hero-text">
          <h1>Блог</h1>
          <p class="hero-sub">Новини, спогади, важливі події та оновлення сайту.<br>Цей блог ведуть близькі Ігоря — щоб пам'ять про нього жила далі.</p>
        </div> -->

        <!-- Контроли: теги + архів по роках -->
        <div class="blog-controls">
          <span class="blog-controls-label">Теми</span>
          <button class="tag-filter active" onclick="filterPosts('all')">
            <span class="tag-dot"></span> Всі
          </button>
          <button class="tag-filter" onclick="filterPosts('memory')">
            <span class="tag-dot"></span> Спогади
          </button>
          <button class="tag-filter" onclick="filterPosts('news')">
            <span class="tag-dot"></span> Новини
          </button>
          <button class="tag-filter" onclick="filterPosts('update')">
            <span class="tag-dot"></span> Оновлення
          </button>

          <div class="archive-years">
            <a href="#2026" class="archive-year">2026</a>
            <a href="#2025" class="archive-year">2025</a>
          </div>
        </div>

        <!-- Пости 2026 -->
        <div class="year-divider" id="2026"><span>2026</span></div>

        <div class="blog-list">

          <article class="blog-post" data-tag="memory">
            <a href="posts/post-1.html" class="post-thumb">
              <img src="img/posts/post-1.jpg" alt="Прев'ю поста" />
            </a>
            <div class="post-info">
              <div class="post-meta">
                <span class="post-tag-badge">Спогади</span>
                <p class="date">25 квітня 2026</p>
              </div>
              <h3><a href="posts/post-1.html"><span class="accent-gold">З Днем народження, синку...</span></a></h3>
              <p class="post-excerpt">
                Сьогодні день, який мав би бути святом — моєму синові сьогодні виповнилося б 30 років.
                Мали б зібратися разом, сміятися, жартувати, згадувати кумедні моменти. Але замість цього
                я пишу тобі листа, який ти ніколи не прочитаєш.
              </p>
              <a href="posts/post-1.html" class="post-cta">
                Читати далі <span class="post-cta-arrow">→</span>
              </a>
            </div>
          </article>

        </div>

        <!-- Пости 2025 (поки порожньо — показуємо плейсхолдер) -->
        <div class="year-divider" id="2025"><span>2025</span></div>
        <div class="blog-list">
          <!-- Нові пости 2025 будуть тут -->
        </div>

      </div>
    </section>
  </main>

  <footer class="site-footer">
    <div class="container footer-inner">
      <div class="footer-left">
        <p>Пам'яті Ігоря «Слона» Утюжа.</p>
        <p class="footer-muted">Усі матеріали належать родині Ігоря Утюжа.</p>
        <!-- Контакти у footer для зручності -->
<!--         <div class="footer-contacts">
          <a href="tel:+380984474975">📞 098 447 49 75</a>
          <a href="mailto:anin2k@ukr.net">✉ anin2k@ukr.net</a>
          <a href="contact.html">Написати родині →</a>
        </div> -->
      </div>
      <div class="footer-right">
        <p class="footer-muted">18.04.1996 — 07.12.2023</p>
      </div>
    </div>
  </footer>

  <script>
    function filterPosts(tag) {
      // Оновлюємо активну кнопку
      document.querySelectorAll('.tag-filter').forEach(btn => btn.classList.remove('active'));
      event.currentTarget.classList.add('active');

      // Фільтруємо статті
      document.querySelectorAll('.blog-post').forEach(post => {
        if (tag === 'all' || post.dataset.tag === tag) {
          post.style.display = '';
        } else {
          post.style.display = 'none';
        }
      });
    }
  </script>
</body>
</html>
