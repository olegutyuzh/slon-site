{
  "extends": [
    "development"
  ],
  "hints": {
    "compat-api/css": [
      "default",
      {
        "ignore": [
          "text-wrap",
          "text-wrap: balance"
        ]
      }
    ],
    "axe/name-role-value": [
      "default",
      {
        "link-name": "off",
        "button-name": "off"
      }
    ]
  },
  "browserslist": [
    "defaults",
    "not ie 11",
    "not and_chr <= 147",
    "not and_ff <= 150",
    "not chrome <= 148",
    "not edge <= 147",
    "not firefox <= 150",
    "not ios_saf <= 26.4",
    "not opera <= 131",
    "not safari <= 26.4",
    "not samsung <= 29"
  ]
}